`timescale 1ns / 1ps

module counter_3bit_tb;

    // 1. Declare Signals
    reg clk;
    reg rst_n;
    wire [2:0] count;

    // 2. Instantiate the Unit Under Test (UUT)
    counter_3bit uut (
        .clk(clk),
        .rst_n(rst_n),
        .count(count)
    );

    // 3. Clock Generation (100MHz / 10ns period)
    always begin
        #5 clk = ~clk;
    end

    // 4. Stimulus Process
    initial begin
        // Initialize Inputs
        clk = 0;
        rst_n = 0; // Start with reset active

        $display("Starting 3-Bit Counter Simulation...");
        
        // Hold reset for 20ns
        #20 rst_n = 1; 
        $display("Reset De-asserted. Counting starts...");

        // Observe the counter for 100ns (Should see 0 to 7 and rollover)
        #100;

        // Test Asynchronous Reset during operation
        $display("Testing Asynchronous Reset at time %t", $time);
        rst_n = 0;
        #10 rst_n = 1;

        #40;
        $display("Simulation Finished.");
        $finish;
    end

    // 5. Monitor Output in Console
    initial begin
        $monitor("Time: %0t | Reset: %b | Count (Binary): %b | Count (Decimal): %d", 
                 $time, rst_n, count, count);
    end

endmodule
